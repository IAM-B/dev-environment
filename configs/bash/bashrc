# Zellij sessions - directory-based naming with timestamp
# zc       → creates "code-DIRNAME-1423"
# zc name  → attaches to existing session "name"
zc() {
  if [ -n "$1" ]; then zellij attach "$1"; else zellij --session "code-${PWD##*/}-$(date +%H%M)" --new-session-with-layout code; fi
}
zd() {
  if [ -n "$1" ]; then zellij attach "$1"; else zellij --session "dev-${PWD##*/}-$(date +%H%M)" --new-session-with-layout dev; fi
}
za() {
  if [ -n "$1" ]; then zellij attach "$1"; else zellij --session "agents-${PWD##*/}-$(date +%H%M)" --new-session-with-layout agents; fi
}
