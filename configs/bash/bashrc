# Create a directory and cd into it
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract any archive
extract() {
    if [ -f "$1" ]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1" ;;
            *.tar.gz)    tar xzf "$1" ;;
            *.tar.xz)    tar xJf "$1" ;;
            *.bz2)       bunzip2 "$1" ;;
            *.rar)       unrar x "$1" ;;
            *.gz)        gunzip "$1" ;;
            *.tar)       tar xf "$1" ;;
            *.tbz2)      tar xjf "$1" ;;
            *.tgz)       tar xzf "$1" ;;
            *.zip)       unzip "$1" ;;
            *.Z)         uncompress "$1" ;;
            *.7z)        7z x "$1" ;;
            *)           echo "'$1' cannot be extracted" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Smart preview for fzf (images via Kitty, text via bat)
_fzf_preview() {
    local file="$1"
    case "$file" in
        *.png|*.jpg|*.jpeg|*.gif|*.bmp|*.webp|*.svg|*.ico)
            if [[ "$TERM" == "xterm-kitty" ]] && command -v kitten &>/dev/null; then
                kitten icat --clear --transfer-mode=memory --place="${FZF_PREVIEW_COLUMNS}x${FZF_PREVIEW_LINES}@0x0" "$file"
            else
                echo "[Image: $file]"
                file "$file"
            fi
            ;;
        *.pdf)
            if command -v pdftotext &>/dev/null; then
                pdftotext "$file" - 2>/dev/null | head -100
            else
                echo "[PDF: $file]"
            fi
            ;;
        *)
            bat --style=numbers --color=always "$file" 2>/dev/null || cat "$file"
            ;;
    esac
}
export -f _fzf_preview

# Open a file with fzf and nvim (image preview in Kitty)
fv() {
    local file
    file=$(fzf --preview '_fzf_preview {}')
    [ -n "$file" ] && nvim "$file"
}

# Display an image in the terminal (shortcut for kitten icat)
img() {
    if [[ "$TERM" != "xterm-kitty" ]]; then
        echo "Requires Kitty terminal to display images"
        return 1
    fi
    kitten icat "$@"
}

# Launch zellij with code layout in the current directory
code() {
    if [ -d "$1" ]; then
        cd "$1"
    fi
    zellij --session "code-${PWD##*/}-$(date +%H%M)" --new-session-with-layout code
}

